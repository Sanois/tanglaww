{
  "expo": {
    "name": "Tanglaw",
    "slug": "Tanglaw",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-dark.png",
    "scheme": "tanglaw",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.tanglaw.tarc",
      "supportsTablet": true,
      "icon": {
        "dark": "./assets/icons/ios-dark.png",
        "light": "./assets/icons/ios-light.png",
        "tinted": "./assets/icons/ios-tinted.png"
      }
    },
    "android": {
      "package": "com.tanglaw.tarc",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#00167a",
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundImage": "./assets/icons/adaptive-icon.png",
        "monochromeImage": "./assets/icons/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "tanglaw"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00167a",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fceed51d-e69c-4535-87d0-3d3f4ca511e5"
      }
    }
  }
}
